    {
      "source": "gogumafarm",
      "title": "RT\ub97c \ubd80\ub974\ub294 \uc694\uc998 \ud56b\ud55c \uc5d1\uc2a4 \ubc08 3\uac00\uc9c0 \uc54c\ub824\ub4dc\ub9bc",
      "clean_title": "rt\ub97c \ubd80\ub974\ub294 \ud56b\ud55c \uc5d1\uc2a4 3\uac00\uc9c0 \uc54c\ub824\ub4dc\ub9bc",
      "excerpt": "RT\ub97c \ubd80\ub974\ub294 \uc694\uc998 \ud56b\ud55c \uc5d1\uc2a4 \ubc08 3\uac00\uc9c0 \uc54c\ub824\ub4dc\ub9bc | \uace0\uad6c\ub9c8\ud31c",
      "clean_excerpt": "rt\ub97c \ubd80\ub974\ub294 \ud56b\ud55c \uc5d1\uc2a4 3\uac00\uc9c0 \uc54c\ub824\ub4dc\ub9bc \uace0\uad6c\ub9c8\ud31c",
      "body_text_preview": "\ubc14\uc774\ub7f4\uc744 \ubd80\ub974\ub294 \uc5d1\uc2a4 \ubc08 \ucf58\ud150\uce20\uac00 \uad81\uae08\ud558\ub2e4\uba74? \uc9c0\uae08 \ud655\uc778\ud574 \ubcf4\uc138\uc694!\n\ucf58\ud150\uce20 \ub9c8\ucf00\ud130\ub77c\uba74 \ud56d\uc0c1 \uc6b0\ub9ac \ube0c\ub79c\ub4dc\uac00 SNS\uc5d0\uc11c \uc5b4\ub5bb\uac8c \uc8fc\ubaa9\ubc1b\uc744\uc9c0 \uace0\ubbfc\ud558\uace4 \ud558\uc8e0. \uc774\ub54c \uac01 \ud50c\ub7ab\ud3fc\uc758 \ud2b9\uc9d5\uc744 \uc774\ud574\ud558\ub294 \uac8c \uc911\uc694\ud574\uc694. \uc720\uc800\uc758 \uc131\uaca9\uacfc \uac8c\uc2dc\ubb3c\uc758 \ud615\uc2dd, \ud0c0\uc784\ub77c\uc778 \uad6c\uc131\uc774 \uc800\ub9c8\ub2e4 \ub2e4\ub974\ub2c8\uae4c\uc694. \uadf8\ub798\uc11c \uc774\ubc88 \uc544\ud2f0\ud074\uc740 \ud2b9\ud788 \uc5d1\uc2a4\uc5d0 \uc9d1\uc911\ud574\uc11c \uc9c0\uae08 \uc720\ud589\ud558\uace0 \uc788\ub294 \ucf58\ud150\uce20 \ubc08\uc744 \uc18c\uac1c\ud560\uac8c\uc694.\ud83e\udee1 \uc54c\ud2f0 \uc2a4\ud0c0\uc758 \uc790\ub9ac\uae4c\uc9c0 \ud55c \uac78\uc74c \ub2e4\uac00\uac00 \ubd05",
      "clean_body_preview": "\ubc14\uc774\ub7f4\uc744 \ubd80\ub974\ub294 \uc5d1\uc2a4 \ucf58\ud150\uce20\uac00 \uad81\uae08\ud558\ub2e4\uba74 \ud655\uc778\ud574 \ubcf4\uc138\uc694 \ub9c8\ucf00\ud130\ub77c\uba74 \ud56d\uc0c1 \ube0c\ub79c\ub4dc\uac00 sns\uc5d0\uc11c \uc5b4\ub5bb\uac8c \uc8fc\ubaa9\ubc1b\uc744\uc9c0 \uace0\ubbfc\ud558\uace4 \ud558\uc8e0 \uc774\ub54c \ud50c\ub7ab\ud3fc\uc758 \ud2b9\uc9d5\uc744 \uc774\ud574\ud558\ub294 \uc911\uc694\ud574\uc694 \uc720\uc800\uc758 \uc131\uaca9\uacfc \uac8c\uc2dc\ubb3c\uc758 \ud615\uc2dd \ud0c0\uc784\ub77c\uc778 \uad6c\uc131\uc774 \uc800\ub9c8\ub2e4 \ub2e4\ub974\ub2c8\uae4c\uc694 \uadf8\ub798\uc11c \uc544\ud2f0\ud074\uc740 \ud2b9\ud788 \uc5d1\uc2a4\uc5d0 \uc9d1\uc911\ud574\uc11c \uc720\ud589\ud558\uace0 \ubc08\uc744 \uc18c\uac1c\ud560\uac8c\uc694 \uc54c\ud2f0 \uc2a4\ud0c0\uc758 \uc790\ub9ac\uae4c\uc9c0 \uac78\uc74c \ub2e4\uac00\uac00 \ubd05\uc2dc\ub2e4 \ud0c0\uc784\ub77c\uc778\uc5d0\uc11c \uc720\ub3c5 \uc790\uc8fc \ubcf4\uc774\ub294 \ud074\ub9ad \uc720\ub3c4\ud615 \ud3ec\ub9f7 \uc774\uc5d0\uc694 \ubcf8\ubb38\uc740 \uc774",
