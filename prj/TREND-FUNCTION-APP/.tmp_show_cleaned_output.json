      "title": "\ud788\ud37c\u00b7\ud0dc\ub2dd\uc2a4\ud2f0\ucee4\u00b7\uba54\uc9c0\ub8e8\uc2dc! \uad7f\uc988 \uae30\ud68d \uc911\uc774\ub77c\uba74 \ubd10\uc57c \ud560 \ud488\uc808 \ub300\ub780 \uad7f\uc988 10\uac00\uc9c0",
      "clean_title": "\ud788\ud37c \ud0dc\ub2dd\uc2a4\ud2f0\ucee4 \uba54\uc9c0\ub8e8\uc2dc \uad7f\uc988 \uae30\ud68d \uc911\uc774\ub77c\uba74 \ubd10\uc57c \ud488\uc808 \ub300\ub780 \uad7f\uc988 10\uac00\uc9c0",
      "excerpt": "\ud788\ud37c\u00b7\ud0dc\ub2dd\uc2a4\ud2f0\ucee4\u00b7\uba54\uc9c0\ub8e8\uc2dc! \uad7f\uc988 \uae30\ud68d \uc911\uc774\ub77c\uba74 \ubd10\uc57c \ud560 \ud488\uc808 \ub300\ub780 \uad7f\uc988 10\uac00\uc9c0 | \uace0\uad6c\ub9c8\ud31c",
      "clean_excerpt": "\ud788\ud37c \ud0dc\ub2dd\uc2a4\ud2f0\ucee4 \uba54\uc9c0\ub8e8\uc2dc \uad7f\uc988 \uae30\ud68d \uc911\uc774\ub77c\uba74 \ubd10\uc57c \ud488\uc808 \ub300\ub780 \uad7f\uc988 10\uac00\uc9c0 \uace0\uad6c\ub9c8\ud31c",
      "body_text_preview": "\uc694\uc998 SNS\ub97c \ubcf4\uba74 \uc720\uba85 \ube0c\ub79c\ub4dc\uc758 \uc81c\ud488\uc774 \uc544\ub2cc\ub370\ub3c4 \uc720\ub3c5 \ub208\uc5d0 \ub744\ub294 \uc544\uc774\ud15c\ub4e4\uc774 \uc788\uc9c0 \uc54a\ub098\uc694? \uc21c\uc2dd\uac04\uc5d0 \ud488\uc808 \ub300\ub780\uc744 \uc77c\uc73c\ud0a4\ub294 \ube44\uacf5\uc2dd \uad7f\uc988\ub4e4\uc774 \uc5b4\ub290\uc0c8 \ud2b8\ub80c\ub4dc\uc758 \uc911\uc2ec\uc5d0 \uc11c \uc788\ub294\ub370\uc694. \uc544\uc8fc \uc791\uc740 \ubd80\ubd84\uae4c\uc9c0\ub3c4 \ucde8\ud5a5\uc73c\ub85c \ucc44\uc6b0\uace0 \uc2f6\uc5b4 \ud558\ub294 \uc18c\ube44\uc790\ub4e4\uc774 \uc9c1\uc811 \uad7f\uc988 \ud2b8\ub80c\ub4dc\ub97c \ub9cc\ub4e4\uc5b4\uac00\uace0 \uc788\ub294 \uac70\uc608\uc694. \uc774\ubc88 \uc544\ud2f0\ud074\uc5d0\uc11c\ub294 \uc9c0\uae08 SNS\uc5d0\uc11c \uac00\uc7a5 \ub728\uac81\uac8c \ub5a0\uc624\ub974\uace0 \uc788\ub294 \ub77c\uc774\uc9d5 \uad7f\uc988\ub4e4\uc744 \uc9d1\uc911 \uc870\uba85\ud574 \ubd24\uc5b4\uc694. Z\uc138\ub300\ub4e4\uc758 \ub9c8\uc74c\uc744",
      "clean_body_preview": "sns\ub97c \ubcf4\uba74 \uc720\uba85 \ube0c\ub79c\ub4dc\uc758 \uc81c\ud488\uc774 \uc544\ub2cc\ub370\ub3c4 \uc720\ub3c5 \ub208\uc5d0 \ub744\ub294 \uc544\uc774\ud15c\ub4e4\uc774 \uc788\uc9c0 \uc54a\ub098\uc694 \uc21c\uc2dd\uac04\uc5d0 \ud488\uc808 \ub300\ub780\uc744 \uc77c\uc73c\ud0a4\ub294 \ube44\uacf5\uc2dd \uad7f\uc988\ub4e4\uc774 \uc5b4\ub290\uc0c8 \ud2b8\ub80c\ub4dc\uc758 \uc911\uc2ec\uc5d0 \uc788\ub294\ub370\uc694 \uc544\uc8fc \uc791\uc740 \ubd80\ubd84\uae4c\uc9c0\ub3c4 \ucde8\ud5a5\uc73c\ub85c \ucc44\uc6b0\uace0 \uc2f6\uc5b4 \ud558\ub294 \uc18c\ube44\uc790\ub4e4\uc774 \uc9c1\uc811 \uad7f\uc988 \ud2b8\ub80c\ub4dc\ub97c \ub9cc\ub4e4\uc5b4\uac00\uace0 \uac70\uc608\uc694 \uc544\ud2f0\ud074\uc5d0\uc11c\ub294 sns\uc5d0\uc11c \ub728\uac81\uac8c \ub5a0\uc624\ub974\uace0 \ub77c\uc774\uc9d5 \uad7f\uc988\ub4e4\uc744 \uc9d1\uc911 \uc870\uba85\ud574 \ubd24\uc5b4\uc694 z\uc138\ub300\ub4e4\uc758 \ub9c8\uc74c\uc744 \uc800\uaca9\ud55c \ub9e4\ub825 \ud3ec\uc778\ud2b8\ub294 \ubb3c\ub860 \ube0c\ub79c\ub4dc \uc785\uc7a5\uc5d0\uc11c",
